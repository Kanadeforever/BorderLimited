// BorderLimitedConfig.rc — user layout, CLI-compatible
#include "resource.h"

#ifndef WS_POPUP
#define WS_POPUP         0x80000000
#define WS_CAPTION       0x00C00000
#define WS_SYSMENU       0x00080000
#define WS_MINIMIZEBOX   0x00020000
#define WS_VSCROLL       0x00200000
#define WS_TABSTOP       0x00010000
#define WS_GROUP         0x00020000
#define DS_SETFONT       0x40
#define DS_MODALFRAME    0x80
#define ES_AUTOHSCROLL   0x0080
#define ES_NUMBER        0x2000
#define CBS_DROPDOWNLIST 0x0003
#define BS_AUTORADIOBUTTON  0x0009
#define BS_AUTOCHECKBOX  0x0003
#define IDOK            1
#define IDCANCEL        2
#endif

1 24 "manifest.xml"

// Application icon
IDI_MAIN ICON "../../../icon.ico"

IDD_MAIN DIALOGEX 0, 0, 380, 325
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_MINIMIZEBOX
CAPTION "BorderLimited Config"
FONT 8, "Segoe UI", 400, 0, 0x0
BEGIN
    GROUPBOX        "Window Mode",IDC_GRP_MODE,7,7,364,30
    CONTROL         "FullScreen",IDC_SIZE_FULLSCREEN,"Button",BS_AUTORADIOBUTTON|WS_GROUP,18,18,70,12
    CONTROL         "Custom",IDC_SIZE_CUSTOM,"Button",BS_AUTORADIOBUTTON,155,18,56,12
    CONTROL         "Borderless",IDC_SIZE_BORDERLESS,"Button",BS_AUTORADIOBUTTON,278,18,70,12

    GROUPBOX        "Custom Position",IDC_GRP_POS,7,42,364,34
    LTEXT           "X:",-1,18,56,12,8
    EDITTEXT        IDC_POS_X,31,54,56,12,ES_AUTOHSCROLL|ES_NUMBER
    LTEXT           "Y:",-1,110,56,12,8
    EDITTEXT        IDC_POS_Y,122,54,56,12,ES_AUTOHSCROLL|ES_NUMBER
    LTEXT           "W:",-1,199,56,14,8
    EDITTEXT        IDC_POS_W,213,54,56,12,ES_AUTOHSCROLL|ES_NUMBER
    LTEXT           "H:",-1,289,56,14,8
    EDITTEXT        IDC_POS_H,304,54,56,12,ES_AUTOHSCROLL|ES_NUMBER

    GROUPBOX        "Crop Offsets",IDC_GRP_OFF,7,81,364,34
    LTEXT           "Left:",-1,14,96,18,8
    EDITTEXT        IDC_OFF_L,31,94,56,12,ES_AUTOHSCROLL|ES_NUMBER
    LTEXT           "Top:",-1,104,96,18,8
    EDITTEXT        IDC_OFF_T,122,94,56,12,ES_AUTOHSCROLL|ES_NUMBER
    LTEXT           "Right:",-1,193,96,20,8
    EDITTEXT        IDC_OFF_R,213,94,56,12,ES_AUTOHSCROLL|ES_NUMBER
    LTEXT           "Bottom:",-1,277,96,27,8
    EDITTEXT        IDC_OFF_B,304,94,56,12,ES_AUTOHSCROLL|ES_NUMBER

    GROUPBOX        "Window Behavior",IDC_GRP_BEH,7,120,364,72
    CONTROL         "Maximize",IDC_CHK_MAXIMIZE,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,31,129,100,12
    CONTROL         "TopMost",IDC_CHK_TOPMOST,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,145,129,100,12
    CONTROL         "Remove Menu Bar",IDC_CHK_REMOVEMENUS,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,259,129,100,12
    CONTROL         "Lock Cursor",IDC_CHK_LOCKCURSOR,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,31,143,100,12
    CONTROL         "Disable Win Key",IDC_CHK_DISABLEWK,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,145,143,100,12
    CONTROL         "Hide Taskbar",IDC_CHK_HIDETASKBAR,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,259,143,100,12
    CONTROL         "Hide Cursor",IDC_CHK_HIDECURSOR,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,31,159,100,12
    CONTROL         "Override DPI",IDC_CHK_OVERRIDEDPI,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,145,159,100,12
    CONTROL         "Enable Log",IDC_CHK_ENABLELOG,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,259,159,100,12
    CONTROL         "UE3 Mode (D3D9)",IDC_CHK_UE3MODE,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,31,175,100,12

    GROUPBOX        "Advanced",IDC_GRP_ADV,7,198,364,75
    LTEXT           "Poll (ms):",IDC_LBL_POLL,14,210,42,9
    EDITTEXT        IDC_POLL,58,208,50,12,ES_AUTOHSCROLL|ES_NUMBER
    LTEXT           "UE3 Res:",IDC_LBL_UE3RES,14,232,42,9
    EDITTEXT        IDC_UE3W,58,230,50,12,ES_AUTOHSCROLL|ES_NUMBER
    LTEXT           "x",-1,119,231,8,8
    EDITTEXT        IDC_UE3H,132,230,50,12,ES_AUTOHSCROLL|ES_NUMBER
    LTEXT           "Monitor:",IDC_LBL_MONITOR,208,210,35,9
    COMBOBOX        IDC_MONITOR,243,208,120,56,CBS_DROPDOWNLIST|WS_VSCROLL
    LTEXT           "Delay (ms):",IDC_LBL_DELAY,14,254,48,9
    EDITTEXT        IDC_DELAY,58,252,50,12,ES_AUTOHSCROLL|ES_NUMBER
    PUSHBUTTON      "Preview...",IDC_BTN_PREVIEW,243,249,120,18

    PUSHBUTTON      "Save",IDC_BTN_SAVE,303,289,60,16
    PUSHBUTTON      "Defaults",IDC_BTN_DEFAULTS,213,289,60,16
    PUSHBUTTON      "English",IDC_BTN_LANG,14,289,60,16
    PUSHBUTTON      "...",IDC_BTN_EXTENDED,90,289,60,16
END

// ── 扩展选项对话框 (文字由 ExtDlgProc 运行时设置) ──────────
IDD_EXTENDED DIALOGEX 0, 0, 360, 180
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION ""
FONT 8, "Segoe UI", 400, 0, 0x0
BEGIN
    GROUPBOX        "",IDC_GRP_MODE,10,10,340,100
    CONTROL         "",IDC_CHK_HOTKEY_ENABLE,"Button",BS_AUTOCHECKBOX|WS_TABSTOP,20,28,100,14
    LTEXT           "",IDC_LBL_POLL,20,52,80,12
    EDITTEXT        IDC_HOTKEY_CODE,105,50,50,14,ES_AUTOHSCROLL|ES_NUMBER
    LTEXT           "",IDC_LBL_DELAY,20,78,50,12
    CONTROL         "Alt",IDC_HOTKEY_MOD_ALT,"Button",BS_AUTORADIOBUTTON|WS_GROUP,75,76,40,14
    CONTROL         "Ctrl",IDC_HOTKEY_MOD_CTRL,"Button",BS_AUTORADIOBUTTON,120,76,40,14
    CONTROL         "Shift",IDC_HOTKEY_MOD_SHIFT,"Button",BS_AUTORADIOBUTTON,165,76,45,14
    CONTROL         "Win",IDC_HOTKEY_MOD_WIN,"Button",BS_AUTORADIOBUTTON,215,76,40,14
    DEFPUSHBUTTON   "",IDOK,200,155,60,22
    PUSHBUTTON      "",IDCANCEL,270,155,60,22
END
